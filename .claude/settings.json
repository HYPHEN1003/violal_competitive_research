{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout -b *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Grep(./.env)",
      "Grep(./.env.*)",
      "Grep(./secrets/**)",
      "Grep(**/*.pem)",
      "Grep(**/*.key)",
      "Grep(**/credentials.json)",
      "Grep(**/service-account*.json)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git checkout -- .)",
      "Bash(git branch -D *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(head .env*)",
      "Bash(head */.env*)",
      "Bash(tail .env*)",
      "Bash(tail */.env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(cat **/credentials*)",
      "Bash(cat **/service-account*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/remind-mco-review.sh",
            "if": "Bash(gh pr create *)"
          },
          {
            "type": "command",
            "command": ".claude/hooks/guard-dangerous-commands.sh",
            "if": "Bash(git *)|Bash(rm *)|Bash(chmod *)|Bash(curl *)|Bash(wget *)"
          },
          {
            "type": "command",
            "command": ".claude/hooks/detect-secret-leak.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/log-commands.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/require-tests-for-pr.sh",
            "if": "Bash(gh pr create *)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/detect-secret-leak.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-rls-on-migration.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-lint.sh"
          }
        ]
      }
    ]
  }
}
